# Приклад для локального запуску або для копіювання в Render → Environment.
# Секрети не коміть у Git.

# MySQL (обовʼязково на проді; локально за замовчуванням у application.yml)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=schools
MYSQL_USER=root
MYSQL_PASSWORD=your_password

# JWT (на проді — довгий випадковий рядок, мінімум 32 символи)
JWT_SECRET=your-256-bit-secret-key-change-in-production-must-be-at-least-32-chars
# JWT_EXPIRATION_MS=86400000
# JWT_REFRESH_EXPIRATION_MS=604800000

# URL фронтенду (листи з посиланням на логін; CORS за потреби)
FRONTEND_BASE_URL=http://localhost:4200

# CORS: для продакшену — URL фронту (через кому), напр. https://online-school-frontend-rose.vercel.app
# Локально merge-localhost додає localhost:4200 лише коли вже задані явні origin у змінній вище.
# Якщо CORS_ALLOWED_ORIGINS не задано — бекенд дозволяє будь-який origin (pattern *), зручно для швидкого старту.
# CORS_ALLOWED_ORIGINS=https://online-school-frontend-rose.vercel.app
# CORS_MERGE_LOCALHOST=true

# Render підставляє порт автоматично; локально зазвичай 8080
# PORT=8080

# Куди зберігати файли ДЗ. Якщо не задано — ${java.io.tmpdir}/education-homework (завжди writable, зручно для Docker).
# Локально можна: HOMEWORK_UPLOAD_DIR=uploads/homework
# HOMEWORK_UPLOAD_DIR=/tmp/homework
